# ============================================================
# HEALY Backend — Environment Variables
# Referensi: HEALY_Master_Blueprint.md Section 7.2
# ============================================================
# Salin file ini menjadi .env:  cp .env.example .env

# Server
APP_PORT=8080
APP_ENV=development              # development | production

# Database (TimescaleDB / PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=healy_user
DB_PASSWORD=healy_password
DB_NAME=healy_db
DB_SSLMODE=disable

# JWT Authentication
JWT_SECRET=your-secret-key-min-32-chars
JWT_EXPIRY_HOURS=24

# WebSocket Paths
WS_DEVICE_PATH=/ws/device        # ESP32 connect ke sini
WS_CLIENT_PATH=/ws/telemetry     # Frontend connect ke sini

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
